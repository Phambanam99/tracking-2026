VITE_GATEWAY_HTTP_BASE=http://localhost:18080
VITE_GATEWAY_WS_URL=ws://localhost:18080/ws/live/websocket
VITE_SHIP_TRACKING_ENABLED=false

# Map provider config (optional)
# - Set default provider id from builtin or custom env providers.
# - Leave empty to use builtin default (osm).
VITE_MAP_DEFAULT_PROVIDER=osm

# JSON array of custom/override providers.
# Supported sourceType: osm, xyz, tms, wms, wmts, mvt
# Tip: keep this as one line in .env files.
VITE_MAP_PROVIDERS=[{"id":"custom-osm","name":"Custom OSM","category":"custom","sourceType":"osm"},{"id":"custom-xyz","name":"Custom XYZ","category":"custom","sourceType":"xyz","url":"https://tiles.example.com/xyz/{z}/{x}/{y}.png"},{"id":"custom-tms","name":"Custom TMS","category":"custom","sourceType":"tms","url":"https://tiles.example.com/tms/{z}/{x}/{-y}.png"},{"id":"custom-wms","name":"Custom WMS","category":"custom","sourceType":"wms","url":"https://wms.example.com/service","wmsLayers":"workspace:layer_name","wmsVersion":"1.3.0","wmsFormat":"image/png"},{"id":"custom-wmts","name":"Custom WMTS","category":"custom","sourceType":"wmts","url":"https://wmts.example.com/service","wmtsLayer":"world-basemap","wmtsMatrixSet":"GoogleMapsCompatible","wmtsFormat":"image/png","wmtsStyle":"default","wmtsProjection":"EPSG:3857","maxZoom":5},{"id":"custom-mvt","name":"Custom MVT","category":"custom","sourceType":"mvt","url":"https://tiles.example.com/mvt/{z}/{x}/{y}.pbf"}]
