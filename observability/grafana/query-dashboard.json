      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"service-query\",status=~\"4..\"}[1m])) by (status)",
          "legendFormat": "{{ status }}"
        }
      ],
      "title": "4xx / 5xx Error Rate",
      "type": "timeseries"
    },
