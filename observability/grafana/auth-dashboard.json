          "legendFormat": "403 Forbidden"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"service-auth\",status=~\"5..\"}[1m]))",
          "legendFormat": "5xx errors"
