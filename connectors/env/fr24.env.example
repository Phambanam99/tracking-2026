# Copy to connectors/env/fr24.env and fill API_KEY
GATEWAY_URL=http://host.docker.internal:18080
API_KEY=trk_live_replace_me
SOURCE_ID=FR24-GLOBAL
LOG_LEVEL=INFO
VERIFY_TLS=true
SEND_SOURCE_HEADER=true
MAX_RECORDS_PER_BATCH=1000
TARGET_PAYLOAD_BYTES=225280
REQUEST_TIMEOUT_SECONDS=10
RETRY_ATTEMPTS=3
BASE_RETRY_DELAY_SECONDS=1.0
FR24_REFRESH_INTERVAL_SECONDS=60
FR24_TIMEOUT_SECONDS=10
FR24_MAX_CONCURRENT_REQUESTS=5
