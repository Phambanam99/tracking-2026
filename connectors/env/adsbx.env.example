# Copy to connectors/env/adsbx.env and fill API_KEY
GATEWAY_URL=http://host.docker.internal:18080
API_KEY=trk_live_replace_me
SOURCE_ID=ADSBX-SNAPSHOT
LOG_LEVEL=INFO
VERIFY_TLS=true
SEND_SOURCE_HEADER=true
MAX_RECORDS_PER_BATCH=1000
TARGET_PAYLOAD_BYTES=225280
REQUEST_TIMEOUT_SECONDS=10
RETRY_ATTEMPTS=3
BASE_RETRY_DELAY_SECONDS=1.0
ADSBX_REFRESH_INTERVAL_SECONDS=60
ADSBX_URL=https://globe.adsbexchange.com
ADSBX_HEADLESS=true
ADSBX_INCLUDE_DERIVED_SPEED_HEADING=true
ADSBX_CHROME_BINARY=/usr/bin/chromium
